#!/usr/bin/env bash
# Sapphire pre-push guard — the client-side enforcement of the branch rules.
# Installed by `bash dev/setup-contributor.sh <handle>` (sets core.hooksPath=.githooks).
#
# Blocks, before anything reaches GitHub:
#   0. Any push when `sapphire.handle` is not configured (run setup first).
#   1. ANY push to a protected branch (main / master / a main-backup-*).
#   2. Any branch not named  <handle>/<slug>  with handle in {rohan,hayes,gavin}.
#   3. A branch whose prefix doesn't match this clone's configured `sapphire.handle`
#      (so hayes can't push a `gavin/...` branch).
# Tag pushes pass through (not a branch-rule concern).
#
# And WARNS (never blocks by default) on:
#   • Gate 1     — Python changed → full suite must be green (this one DOES block on RED).
#   • Gate 3.5   — doc-freshness (warn; block via SAPPHIRE_DOCGATE=block).
#   • Gate 3.6   — base-freshness: branch base behind origin/main (warn; block via SAPPHIRE_BASEGATE=block).
#
# This is a guardrail for cooperating agents. It is bypassable with `git push --no-verify`
# — doing so is a hard violation of dev/CONTRIBUTOR_RULES.md; the detective backstop
# `dev/audit-history.sh` catches a direct push to main after the fact.
set -euo pipefail

PROTECTED_RE='^(main|master|main-backup-.*)$'
HANDLE_RE='^(rohan|hayes|gavin)$'
ZERO='0000000000000000000000000000000000000000'

handle="$(git config --get sapphire.handle || true)"

block() { echo "" >&2; echo "  ✗ PUSH BLOCKED — $1" >&2; echo "    See dev/CONTRIBUTOR_RULES.md." >&2; echo "" >&2; exit 1; }

# 0. Require a configured, valid handle before any push.
if [[ -z "$handle" ]]; then
  block "sapphire.handle is not set. Run: bash dev/setup-contributor.sh <handle>"
fi
if [[ ! "$handle" =~ $HANDLE_RE ]]; then
  block "git config sapphire.handle='$handle' is invalid (must be rohan|hayes|gavin). Re-run dev/setup-contributor.sh."
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue

  # Tag pushes are not a branch-rule concern — let them through.
  [[ "$remote_ref" == refs/tags/* ]] && continue

  # remote_ref looks like refs/heads/<branch>
  branch="${remote_ref#refs/heads/}"
  [ -z "$branch" ] && continue

  # 1. never push (create/update/delete) a protected branch.
  #    Approver carve-out: rohan may push to main for post-merge bookkeeping.
  #    Gate 1 still runs when Python files are included in the push (same check as
  #    feature branches).  All contributor protections (hayes/gavin) are unchanged.
  #    RESIDUAL RISK (by design): `$handle` is a local `git config sapphire.handle` value, and
  #    git hooks are advisory (bypassable with --no-verify), so a contributor COULD set
  #    handle=rohan and push straight to main — this hook cannot truly prevent that locally.
  #    The real enforcement is the DETECTIVE backstop `dev/audit-history.sh`, which flags any
  #    commit that landed on main without a PR ("(#NN)") marker. This carve-out exists only to
  #    remove the structural need for `--no-verify` on legitimate approver bookkeeping.
  if [[ "$branch" =~ $PROTECTED_RE ]]; then
    if [[ "$handle" == "rohan" ]]; then
      # Compute the base for the diff (same logic as the Gate-1 check below).
      _base="$remote_sha"
      if [[ "$_base" == "$ZERO" ]]; then
        _base="$(git rev-parse --verify --quiet origin/main || true)"
      fi
      if [[ -n "$_base" ]] && git rev-parse --verify --quiet "$_base" >/dev/null 2>&1; then
        _changed="$(git diff --name-only "$_base" "$local_sha" 2>/dev/null || true)"
      else
        _changed="$(git show --name-only --format='' "$local_sha" 2>/dev/null || true)"
      fi
      if printf '%s\n' "$_changed" | grep -qE '\.py$'; then
        echo "  • rohan pushing to '$branch' — Python changed, running Gate 1 (dev/run-tests.sh)…" >&2
        root="$(git rev-parse --show-toplevel)"
        if ! bash "$root/dev/run-tests.sh" >&2; then
          block "the test suite is RED. Fix it before pushing (Gate 1 must be green)."
        fi
      fi
      continue  # approver carve-out: allow rohan's push to main (no Python → free)
    fi
    block "direct pushes to '$branch' are forbidden. Open a PR from your <handle>/<slug> branch."
  fi

  # deleting a feature branch (local side all-zero) is fine
  [ "$local_sha" = "$ZERO" ] && continue

  # 2. branch must be <handle>/<slug>
  if [[ ! "$branch" =~ ^(rohan|hayes|gavin)/.+ ]]; then
    block "branch '$branch' is not allowed. Use <handle>/<slug> (handle ∈ rohan|hayes|gavin)."
  fi

  # 3. branch prefix must match this clone's configured handle
  prefix="${branch%%/*}"
  if [[ "$prefix" != "$handle" ]]; then
    block "you are '$handle' but tried to push a '$prefix/...' branch. Push only your own '$handle/...' branches."
  fi

  # 4. if this push changes any Python, the full suite must be green first (Gate 1, local).
  base="$remote_sha"
  if [[ "$base" == "$ZERO" ]]; then
    # new branch on the remote — diff against origin/main if we have it, else the merge base with HEAD
    base="$(git rev-parse --verify --quiet origin/main || true)"
  fi
  if [[ -n "$base" ]] && git rev-parse --verify --quiet "$base" >/dev/null; then
    changed="$(git diff --name-only "$base" "$local_sha" 2>/dev/null || true)"
  else
    # No base to diff against (disconnected repo, no origin/main): list files in the
    # tip commit itself rather than a (wrong) working-tree diff.
    changed="$(git show --name-only --format='' "$local_sha" 2>/dev/null || true)"
  fi
  if printf '%s\n' "$changed" | grep -qE '\.py$'; then
    echo "  • Python changed in this push — running Gate 1 (dev/run-tests.sh) before allowing push…" >&2
    root="$(git rev-parse --show-toplevel)"
    if ! bash "$root/dev/run-tests.sh" >&2; then
      block "the test suite is RED. Fix it before pushing (Gate 1 must be green)."
    fi
  fi

  # Gate 3.5 — doc-freshness check.
  # Default (warn mode): prints violations, always exits 0 — never blocks a push.
  # Flip to block mode: export SAPPHIRE_DOCGATE=block
  if [[ -n "$base" ]] && git rev-parse --verify --quiet "$base" >/dev/null; then
    doc_range="$base..$local_sha"
  else
    doc_range="$local_sha^..$local_sha"
  fi
  root="$(git rev-parse --show-toplevel)"
  if [[ -x "$root/dev/check-docs.sh" ]]; then
    if [[ "${SAPPHIRE_DOCGATE:-warn}" == "block" ]]; then
      # Block mode: check-docs exits 1 on violations; hook calls block() to abort the push.
      if ! bash "$root/dev/check-docs.sh" "$doc_range" >&2; then
        block "Gate 3.5 doc-freshness violation(s). Run 'dev/check-docs.sh $doc_range' for details."
      fi
    else
      # Warn mode (default): --warn flag makes check-docs always exit 0.
      bash "$root/dev/check-docs.sh" --warn "$doc_range" >&2 || true
    fi
  fi

  # Gate 3.6 — base-freshness (staleness) check.
  # Catches the "branched off a STALE local origin/main" footgun BEFORE it costs the
  # approver a gate cycle (a stale base parallelizes/edits an old engine → merge conflicts
  # or, worse, tests that validated against the wrong base). This clone's local main tree
  # is often left behind by design, so the local `origin/main` ref can be stale too — we
  # therefore FETCH the real remote tip and measure how far this branch's merge-base lags it.
  # Default warn mode (never blocks). Strict shops: export SAPPHIRE_BASEGATE=block
  # (blocks at >= SAPPHIRE_BASEGATE_MAX commits behind, default 1). Offline → silently skips.
  git fetch -q origin main 2>/dev/null || true
  _rmain="$(git rev-parse --verify --quiet FETCH_HEAD || git rev-parse --verify --quiet origin/main || true)"
  if [[ -n "$_rmain" ]]; then
    _mb="$(git merge-base "$local_sha" "$_rmain" 2>/dev/null || true)"
    if [[ -n "$_mb" ]]; then
      _behind="$(git rev-list --count "$_mb..$_rmain" 2>/dev/null || echo 0)"
      if [[ "$_behind" -gt 0 ]]; then
        echo "  • Gate 3.6: branch base is $_behind commit(s) behind origin/main." >&2
        echo "    Rebase before the approver gates:  git fetch origin && git rebase origin/main" >&2
        if [[ "${SAPPHIRE_BASEGATE:-warn}" == "block" && "$_behind" -ge "${SAPPHIRE_BASEGATE_MAX:-1}" ]]; then
          block "Gate 3.6 — base is $_behind commit(s) behind origin/main (block mode). Rebase onto origin/main and re-push."
        fi
      fi
    fi
  fi
done

exit 0
