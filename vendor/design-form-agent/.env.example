# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic API key — used by extract.py to call Claude.
# Get one at https://console.anthropic.com/ (Settings -> API keys).
ANTHROPIC_API_KEY=sk-ant-...

# Slack bot credentials — only needed to run the Slack bot (app.py), not the CLI.
# From your Slack app config at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
