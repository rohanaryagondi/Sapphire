# Model weights — ~17 GB of local checkpoints, never commit. Fetch via scripts/download_models.sh
models/

# Large / re-downloadable data (auto-downloaded by the experiment loaders, or via TDC).
# Curated small test sets under data/wdr91 and data/pgk2 ARE committed (hard to regenerate).
data/solubility/
data/bindingdb_kd.tab
data/weber.tab

# Claude Code session state
.claude/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
build/
dist/

# HuggingFace / torch caches
.cache/
hf_cache/
**/.huggingface/
~/.cache/huggingface

# OS / editor
.DS_Store
.ipynb_checkpoints/
.vscode/
.idea/

